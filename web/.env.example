# Env for the Nuxt BFF (server/api handlers). Same names as the old Next.js app.
# Copy to web/.env (gitignored) or export before `npm run dev`.

# FastAPI backend base URL (auth/*, models/config, chat/stream).
SERVER_BASE_URL=http://localhost:8001

# FastAPI backend base URL for gitlab/* and wiki/projects. Usually the same host.
PYTHON_BACKEND_HOST=http://localhost:8001

# Direct GitLab API access for the default-branch lookup (self-hosted supported).
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
